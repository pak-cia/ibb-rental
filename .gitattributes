# Normalise line endings: stored as LF in the repo, restored to native on checkout.
* text=auto eol=lf

# Force LF for source files regardless of OS.
*.php   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.sh    text eol=lf

# Treat as binary — no diff/merge/normalisation.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary

# Files excluded from the distribution zip but tracked in git.
.gitattributes export-ignore
.gitignore     export-ignore
.distignore    export-ignore
tests/         export-ignore
phpunit.xml    export-ignore
build.sh       export-ignore
package.json   export-ignore
webpack.config.js export-ignore
